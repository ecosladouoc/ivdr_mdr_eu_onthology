        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:comment>Represents a competent authority that supervised companies and institutions in a territory.</rdfs:comment>
        <rdfs:label xml:lang="en">CompetentAuthority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/ContaminationRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">A sample contamination may occur.</rdfs:comment>
        <rdfs:label xml:lang="en">ContaminationRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CorrectiveAction -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-mrh-ontology#fscaId"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An action taken to solve an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">CorrectiveAction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CybersecurityIncident -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CybersecurityIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment>A cibersecurity outcome got as outcome.</rdfs:comment>
        <rdfs:label xml:lang="en">CibersecurityIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CybersecurityRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The device could be victim in a cyber attack.</rdfs:comment>
        <rdfs:label xml:lang="en">CybersecurityRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Device -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Device">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/deviceId"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Represents an IVR or MHR device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DeviceMalfunction -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DeviceMalfunction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment>A device malfunction as outcome</rdfs:comment>
        <rdfs:label xml:lang="en">DeviceMalfunction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DeviceType -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:comment xml:lang="en">Type of device.</rdfs:comment>
        <rdfs:label xml:lang="en">DeviceType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DiagnosticError -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DiagnosticError">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment>A diagnostic error got as outcome.</rdfs:comment>
        <rdfs:label>DiagnosticError</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DiagnosticRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">An error in diagnostic may occur.</rdfs:comment>
        <rdfs:label xml:lang="en">DiagnosticRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Generic Medical Entity</rdfs:comment>
        <rdfs:label>EUMedicalEntity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IVDRiskClass -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IVDRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskClass"/>
        <rdfs:comment xml:lang="en">Class A: Low patient and public health risk
Class B: Moderate patient risk and/or low public health risk
Class C: High patient risk and/or moderate public health risk
Class D: High patient risk and high public health risk</rdfs:comment>
        <rdfs:label xml:lang="en">IVDRiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InSituCorrection -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Corrective action taken in the same place it happened.</rdfs:comment>
        <rdfs:label xml:lang="en">inSituCorrection</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InapropriateShockDelivery -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InapropriateShockDelivery">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment>As a result you got an inapropriate shock delivery</rdfs:comment>
        <rdfs:label xml:lang="en">InapropriateShockDelivery</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Incident -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Incident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/incidentId"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Models an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:comment xml:lang="en">Represents an outcome got because of an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">IncidentOutcome</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InfectionRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">An infection may occur.</rdfs:comment>
        <rdfs:label xml:lang="en">InfectionRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InjuryRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The possibility that a person may suffer physical harm.</rdfs:comment>
        <rdfs:label xml:lang="en">InjuryRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InterferenceRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The possibility the device could receive interferences that affect to the correct behaviour.</rdfs:comment>
        <rdfs:label xml:lang="en">InterferenceRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MDRRiskClass -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskClass"/>
        <rdfs:comment xml:lang="en">Class I: Low Risk, Self-Declaration
Class IIa: Medium-Low Risk, NB Audit
Class IIb: Medium-High Risk, Comprehensive NB Audit
Class III: High Risk, Strictest NB and Design Audit</rdfs:comment>
        <rdfs:label xml:lang="en">MDRRiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MalfunctionRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The possibility that the device may not work in a proper way.</rdfs:comment>
        <rdfs:label xml:lang="en">MalfunctionRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Manufacturer -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/country"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/authorizationNumber"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Represents a company which produces medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MaterialRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The possibility that materials may be damaged.</rdfs:comment>
        <rdfs:label xml:lang="en">MaterialRisk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/NearMissIncident -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Incident"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SeriousIncident"/>
        <rdfs:comment xml:lang="en">An incident that did not result in harm, damage, or loss, but had a potential to do so.</rdfs:comment>
        <rdfs:label xml:lang="en">NearMissIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/PatientHarm -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/PatientHarm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Recall -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A recall done to fix the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RegulatoryFramework -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:comment xml:lang="en">A set of laws, regulations, guidelines and standards that govern activities in a medical domain.</rdfs:comment>
        <rdfs:label xml:lang="en">RegulatoryFramework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/affectedDeviceType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/riskId"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The possibility that an event may occur and have negative effect.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskCategory -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskCategory">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:comment xml:lang="en">Represents a risk category</rdfs:comment>
        <rdfs:label xml:lang="en">RiskCategory</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskClass -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/EUMedicalEntity"/>
        <rdfs:comment xml:lang="en">A risk-oriented device classification.</rdfs:comment>
        <rdfs:label xml:lang="en">RiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SafetyAlert -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/CorrectiveAction"/>
        <rdfs:comment xml:lang="en">A safe alert was raised to mitigate the risk and fix the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">SafeAlert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SeriousIncident -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Incident"/>
        <rdfs:comment xml:lang="en">An incident that supposed a serious harm or damage.</rdfs:comment>
        <rdfs:label xml:lang="en">SeriousIncident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SeriousPacientInjury -->

    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SeriousPacientInjury">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment xml:lang="en">As a result, the patient suffered a serious injury</rdfs:comment>
        <rdfs:label xml:lang="en">SeriousPatientInjury</rdfs:label>
