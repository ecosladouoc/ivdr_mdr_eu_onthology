        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
        <rdfs:comment xml:lang="en">As a result, the patient suffered a serious injury</rdfs:comment>
        <rdfs:label xml:lang="en">serious patient injury</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SoftwareRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/Risk"/>
        <rdfs:comment xml:lang="en">The possibility that software may not work properly.</rdfs:comment>
        <rdfs:label xml:lang="en">software risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SurgicalInterventionRequired -->


    <owl:Class rdf:about="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/SurgicalInterventionRequired">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/IncidentOutcome"/>
