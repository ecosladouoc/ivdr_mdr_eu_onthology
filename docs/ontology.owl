        <rdfs:comment xml:lang="en">The manufacturer&apos;s contact email.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/correctiveActionTaken -->


