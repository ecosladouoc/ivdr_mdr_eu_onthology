        <rdfs:label xml:lang="en">action status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/affectedDeviceType -->


