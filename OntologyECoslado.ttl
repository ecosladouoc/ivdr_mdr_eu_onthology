<urn:swrl:var#ca> rdf:type swrl:Variable .

<urn:swrl:var#date> rdf:type swrl:Variable .

<urn:swrl:var#d> rdf:type swrl:Variable .

<urn:swrl:var#r> rdf:type swrl:Variable .

<urn:swrl:var#dt> rdf:type swrl:Variable .

<urn:swrl:var#m> rdf:type swrl:Variable .

<urn:swrl:var#i> rdf:type swrl:Variable .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :CorrectiveAction ;
                           swrl:argument1 <urn:swrl:var#ca>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:DatavaluedPropertyAtom ;
                                      swrl:propertyPredicate :closureDate ;
                                      swrl:argument1 <urn:swrl:var#ca> ;
                                      swrl:argument2 <urn:swrl:var#date>
                                    ] ;
                          rdf:rest rdf:nil
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate :actionStatus ;
                           swrl:argument1 <urn:swrl:var#ca> ;
                           swrl:argument2 :Close
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :Device ;
                           swrl:argument1 <urn:swrl:var#d>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate :Risk ;
                                      swrl:argument1 <urn:swrl:var#r>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                 swrl:propertyPredicate :deviceType ;
                                                 swrl:argument1 <urn:swrl:var#d> ;
                                                 swrl:argument2 <urn:swrl:var#dt>
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                            swrl:propertyPredicate :affectedDeviceType ;
                                                            swrl:argument1 <urn:swrl:var#r> ;
                                                            swrl:argument2 <urn:swrl:var#dt>
                                                          ] ;
                                                rdf:rest rdf:nil
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate :possiblyAffectedByRisk ;
                           swrl:argument1 <urn:swrl:var#d> ;
                           swrl:argument2 <urn:swrl:var#r>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :Manufacturer ;
                           swrl:argument1 <urn:swrl:var#m>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate :Incident ;
                                      swrl:argument1 <urn:swrl:var#i>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate :Risk ;
                                                 swrl:argument1 <urn:swrl:var#r>
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                            swrl:propertyPredicate :reportingManufacturer ;
                                                            swrl:argument1 <urn:swrl:var#i> ;
                                                            swrl:argument2 <urn:swrl:var#m>
                                                          ] ;
                                                rdf:rest [ rdf:type swrl:AtomList ;
                                                           rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                                       swrl:propertyPredicate :relatedRisk ;
                                                                       swrl:argument1 <urn:swrl:var#i> ;
                                                                       swrl:argument2 <urn:swrl:var#r>
                                                                     ] ;
                                                           rdf:rest [ rdf:type swrl:AtomList ;
                                                                      rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                                                  swrl:propertyPredicate :severity ;
                                                                                  swrl:argument1 <urn:swrl:var#r> ;
                                                                                  swrl:argument2 :Critical
                                                                                ] ;
                                                                      rdf:rest rdf:nil
                                                                    ]
                                                         ]
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate :ManufacturerWithCriticalIncidentReported ;
