           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "The date the event occured."@en ;
           rdfs:label "eventDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
