###  http://xmlns.com/foaf/0.1/name
foaf:name rdfs:subPropertyOf owl:topDataProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#ManufacturerWithCriticalIncidentReported
:ManufacturerWithCriticalIncidentReported rdf:type owl:Class ;
                                          rdfs:subClassOf :Manufacturer ;
                                          rdfs:comment "Manufacturer that reported at least an incident related with critical risk."@en ;
