                                                                                      <http://purl.org/dc/terms/title> "In Vitro Diagnosis and High Risk Medical Devices Ontology"@en ;
                                                                                      rdfs:label "In Vitro Diagnosis and High Risk Medical Devices Ontology EU" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#actionStatus
:actionStatus rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
              rdfs:comment "The corrective action status."@en ;
              rdfs:label "actionStatus"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#affectedDeviceType
:affectedDeviceType rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :DeviceType ;
                    rdfs:comment "Device type affected by determined risk."@en ;
                    rdfs:label "affectedDeviceType"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#affectedRiskClass
:affectedRiskClass rdf:type owl:ObjectProperty ;
                   owl:deprecated "true"^^xsd:boolean .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#country
:country rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
         rdfs:comment "The country where a manufacturer works."@en ;
         rdfs:label "country"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#countryReported
:countryReported rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment "The country the incident was reported from."@en ;
                 rdfs:label "countryReported"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#device
:device rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf owl:topObjectProperty ;
        rdfs:domain :Incident ;
        rdfs:range :Device ;
        rdfs:comment "Device affected by the incident."@en ;
        rdfs:label "device"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#deviceType
:deviceType rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Device ;
            rdfs:range :DeviceType ;
            rdfs:comment "Type of device."@en ;
            rdfs:label "deviceType"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#incident
:incident rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :CorrectiveAction ;
          rdfs:range :Incident ;
          rdfs:comment "Incident related with the corrective action."@en ;
          rdfs:label "incident"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#manufacturer
:manufacturer rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :Manufacturer ;
              rdfs:comment "The company that produces the device."@en ;
              rdfs:label "manufacturer"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#outcome
:outcome rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :IncidentOutcome ;
         rdfs:comment "The incident result."@en ;
         rdfs:label "outcome"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#probability
:probability rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#regulatoryFramework
:regulatoryFramework rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     rdfs:comment "The regulatory framework that rules a device."@en ;
                     rdfs:label "regulatoryFramework"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#relatedRisk
:relatedRisk rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Incident ;
             rdfs:range :Risk ;
             rdfs:comment "Risk related with the incident."@en ;
             rdfs:label "relatedRisk"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#reportingEntity
:reportingEntity rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :Manufacturer .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#reportingManufacturer
:reportingManufacturer rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range :Manufacturer ;
                       rdfs:comment "The manufacturer that reported the incident."@en ;
                       rdfs:label "reportingManufacturer"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#riskCategory
:riskCategory rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Risk ;
              rdfs:range :RiskCategory ;
              rdfs:comment "Category of a risk."@en ;
              rdfs:label "riskCategory" .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#riskClass
:riskClass rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Device ;
           rdfs:range :RiskClass ;
           rdfs:comment "A risk-oriented device classification."@en ;
           rdfs:label "riskClass"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#riskDeviceType
:riskDeviceType rdf:type owl:ObjectProperty ;
                rdfs:comment "DEPRECATED The Device Type related with a risk."@en ;
                rdfs:label "DEPRECATED riskDeviceType"@en ;
                owl:deprecated "true"^^xsd:boolean .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#severity
:severity rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#supervisedBy
:supervisedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :CompetentAuthority ;
              rdfs:comment "The authority that supervises a manufacturer."@en ;
              rdfs:label "supervisedBy"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/mdr-ivdr-eu#inScheme
<http://www.semanticweb.org/kaik/ontologies/2026/3/mdr-ivdr-eu#inScheme> rdf:type owl:ObjectProperty .


