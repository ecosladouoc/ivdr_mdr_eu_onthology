#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:subClassOf :EUMedicalEntity ,
                                    <http://xmlns.com/foaf/0.1/Organization> ;
                    rdfs:comment "Represents a competent authority that supervised companies and institutions in a territory." ;
                    rdfs:label "CompetentAuthority"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "A sample contamination may occur."@en ;
                   rdfs:label "ContaminationRisk"@en .


