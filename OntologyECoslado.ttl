<http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu> rdf:type owl:Ontology ;
                                                                                      owl:versionIRI <http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/1.0.0> ;
                                                                                      owl:imports <http://publications.europa.eu/resource/authority/country/20260318-0> ,
