#################################################################
#    Annotation properties
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/mdr-ivdr-eu#skos:inScheme
skos1:inScheme rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#possiblyAffectedByRisk
:possiblyAffectedByRisk rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range :Risk ;
                        rdfs:comment "Inferred property that relates a device with a risk. Calculated by the relation with relationType."@en ;
                        rdfs:label "possiblyAffectedByRisk"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#skos:inScheme
:skos:inScheme rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain skos:Concept ;
               rdfs:range skos:ConceptScheme ;
               rdfs:comment "in scheme"@en ;
               rdfs:label "is in scheme"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/actionStatus
:actionStatus rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range skos:Concept ;
              rdfs:comment "The corrective action status."@en ;
              rdfs:label "actionStatus"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/affectedDeviceType
:affectedDeviceType rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :DeviceType ;
                    rdfs:comment "Device type affected by determined risk."@en ;
                    rdfs:label "affectedDeviceType"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/country
:country rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range skos:Concept ;
         rdfs:comment "The country where a manufacturer works."@en ;
         rdfs:label "country"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/countryReported
:countryReported rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range skos:Concept ;
                 rdfs:comment "The country the incident was reported from."@en ;
                 rdfs:label "countryReported"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/device
:device rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf owl:topObjectProperty ;
        rdfs:domain :Incident ;
        rdfs:range :Device ;
        rdfs:comment "Device affected by the incident."@en ;
        rdfs:label "device"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/deviceType
:deviceType rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Device ;
            rdfs:range :DeviceType ;
            rdfs:comment "Type of device."@en ;
            rdfs:label "deviceType"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/incident
:incident rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :CorrectiveAction ;
          rdfs:range :Incident ;
          rdfs:comment "Incident related with the corrective action."@en ;
          rdfs:label "incident"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/manufacturer
:manufacturer rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :Manufacturer ;
              rdfs:comment "The company that produces the device."@en ;
              rdfs:label "manufacturer"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/outcome
:outcome rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :IncidentOutcome ;
         rdfs:comment "The incident result."@en ;
         rdfs:label "outcome"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/probability
:probability rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range skos:Concept .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/regulatoryFramework
:regulatoryFramework rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     rdfs:domain :Device ;
                     rdfs:range :RegulatoryFramework ;
                     rdfs:comment "The regulatory framework that rules a device."@en ;
                     rdfs:label "regulatoryFramework"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/relatedRisk
:relatedRisk rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Incident ;
             rdfs:range :Risk ;
             rdfs:comment "Risk related with the incident."@en ;
             rdfs:label "relatedRisk"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/reportingManufacturer
:reportingManufacturer rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range :Manufacturer ;
                       rdfs:comment "The manufacturer that reported the incident."@en ;
                       rdfs:label "reportingManufacturer"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/riskCategory
:riskCategory rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Risk ;
              rdfs:range :RiskCategory ;
              rdfs:comment "Category of a risk."@en ;
              rdfs:label "riskCategory" .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/riskClass
:riskClass rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Device ;
           rdfs:range :RiskClass ;
           rdfs:comment "A risk-oriented device classification."@en ;
           rdfs:label "riskClass"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/severity
:severity rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range skos:Concept .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/supervisedBy
:supervisedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :CompetentAuthority ;
              rdfs:comment "The authority that supervises a manufacturer."@en ;
              rdfs:label "supervisedBy"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#criticalIncidentReported
:criticalIncidentReported rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty ;
                          rdfs:domain :Manufacturer ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Indicates wheter the manufacturer reported an incident with critical risk or not."@en ;
                          rdfs:label "criticalIncidentReported"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The manufacturer's authorization number."@en ;
                     rdfs:label "authorizationNumber"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "The date the action finished."@en ;
             rdfs:label "closureDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/contactEmail
:contactEmail rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "The manufacturer's contact email."@en ;
              rdfs:label "contactEmail"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/correctiveActionDescription
:correctiveActionDescription rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf owl:topDataProperty ;
                             rdfs:domain :CorrectiveAction ;
                             rdfs:range xsd:string ;
                             rdfs:comment "A text describing the corrective action."@en ;
                             rdfs:label "correctiveActionDescription"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Boolean that determines if a corrective action was taken to solve the incident or not."@en ;
                       rdfs:label "correctiveActionTaken"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/detectionDate
:detectionDate rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "The date the incident was detected."@en ;
               rdfs:label "detectionDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/deviceId
:deviceId rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "Device unique identifier."@en ;
          rdfs:label "deviceId"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/deviceName
:deviceName rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "The device name."@en ;
            rdfs:label "deviceName"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/eudamedFscaRef
:eudamedFscaRef rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "EUDAMED identifier for corrective action."@en ;
                rdfs:label "eudamedFscaRef"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The EUDAMED incident reference"@en ;
                    rdfs:label "eudamedIncidentRef"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/eudamedSrn
:eudamedSrn rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "EUDAMED manufacturer identifier."@en ;
            rdfs:label "eudamedSrn"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/eventDate
:eventDate rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "The date the event occured."@en ;
           rdfs:label "eventDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "IMDRF code for the risk."@en ;
           rdfs:label "imdrfCode" .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "A text describing the incident."@en ;
                     rdfs:label "incidentDescription"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/incidentId
:incidentId rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Incident identifier"@en ;
            rdfs:label "incidentId"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/incidentOutcomeDescription
:incidentOutcomeDescription rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf owl:topDataProperty ;
                            rdfs:domain :IncidentOutcome ;
                            rdfs:range xsd:string ;
                            rdfs:comment "A text describing the incident outcome."@en ;
                            rdfs:label "incidentOutcomeDescription"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/intentedPurpose
:intentedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The intented purpose of a device."@en ;
                 rdfs:label "intentedPurpose"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Boolean that determines if devices is active or not."@en ;
          rdfs:label "isActive"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Boolean that determines if device is implantable or not."@en ;
               rdfs:label "isImplantable"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/isIvd
:isIvd rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Boolean that determines if an device is for in vitro diagnosis."@en ;
       rdfs:label "isIvd"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Boolean that determines if a device is reusable."@en ;
            rdfs:label "isReusable"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/manufacturerId
:manufacturerId rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "Manufacturer's unique identifier."@en ;
                rdfs:label "manufacturerId"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/pacientAge
:pacientAge rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "The age of the patient affected."@en ;
            rdfs:label "patientAge"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/pacientSex
:pacientSex rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Sex of the patient affected."@en ;
            rdfs:label "patientSex"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "The date the incident was reported."@en ;
            rdfs:label "reportDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/riskId
:riskId rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :Risk ;
        rdfs:range xsd:string ;
        rdfs:comment "Unique identifier for the risk."@en ;
        rdfs:label "riskId"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "Name of the risk."@en ;
          rdfs:label "riskName"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu/udiDi
:udiDi rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "Identifier for EUDAMED to track device models."@en ;
       rdfs:label "uidDi"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-mrh-ontology#actionDate
ivd-mrh-ontology:actionDate rdf:type owl:DatatypeProperty ;
                            rdfs:subPropertyOf owl:topDataProperty ;
                            rdfs:domain :CorrectiveAction ;
                            rdfs:range xsd:date ;
                            rdfs:comment "The date that the action was started."@en ;
                            rdfs:label "actionDate"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-mrh-ontology#countriesAffected
ivd-mrh-ontology:countriesAffected rdf:type owl:DatatypeProperty ;
                                   rdfs:subPropertyOf owl:topDataProperty ;
                                   rdfs:domain :CorrectiveAction ;
                                   rdfs:range xsd:string ;
                                   rdfs:comment "The countries or region affected by the incident."@en ;
                                   rdfs:label "countriesAffected"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-mrh-ontology#description
ivd-mrh-ontology:description rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf owl:topDataProperty ;
                             rdfs:domain :Risk ;
                             rdfs:range xsd:string ;
                             rdfs:comment "A descriptive text related with the entity."@en ;
                             rdfs:label "description"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-mrh-ontology#devicesAffected
ivd-mrh-ontology:devicesAffected rdf:type owl:DatatypeProperty ;
