:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The manufacturer's authorization number."@en ;
                     rdfs:label "authorizationNumber"@en .


###  http://www.semanticweb.org/kaik/ontologies/2026/3/ivd-high-risk-medical-devices-eu#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "The date the action finished."@en .


